#include <stdio.h>

int main() {
    int array[10];
    for (int i = 0; i < 10; i++) {
        scanf("%d", &array[i]);
    }
    
    printf("Enter number to search: ");
    int search, low = 0, high = 9, found = 0, position;
    scanf("%d", &search);
    
    while (low <= high) {
        int mid = (low + high) / 2;
        if (array[mid] == search) {
            position = mid + 1;
            found = 1;
            break;
        }
        else if (array[mid] < search) {
            low = mid + 1;
        }
        else {
            high = mid - 1;
        }
    }
    
    if (found == 1) {
        printf("Found at position %d", position);
    } else {
        printf("Not in array");
    }
    
    return 0;
}
