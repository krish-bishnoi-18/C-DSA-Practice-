#include <stdio.h>

int main() {
    int array[5];
    for (int i = 0; i < 5; i++)
    {
        scanf("%d",&array[i]);
    }
    printf("Please enter the number which you want to search In array");
    int search,found =0;
    scanf("%d",&search);
    for (int i = 0; i < 5; i++)
    {
        if (search==array[i])
        {
            printf(" The number is located at %d",i+1);
            found = 1;
        }
    }
    if (found==0)
    {
        printf(" The number is Not in the array");
    }
    
    return 0;
}
