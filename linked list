#include <stdio.h>
#include<stdlib.h>
struct node
{
    int data ;
    struct node* next ;
};

int main() {
    struct node* node1 = malloc(sizeof(struct node));
    struct node* node2 = malloc(sizeof(struct node));
    struct node* node3 = malloc(sizeof(struct node));
    node1->data = 10;
    node2->data = 20;
    node3->data = 30;
     
    node1->next = node2;
    node2->next = node3;
    node3->next = NULL;
     struct node* curret = node1;
     while (curret!= NULL)
     {
        printf("%d\n",curret->data);
        curret=curret->next;
     }
    return 0;
}
