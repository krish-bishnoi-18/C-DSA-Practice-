#include <stdio.h>

int main() {
    int array [10];
    for (int i = 0; i < 10; i++)
    {
        scanf("%d",&array[i]);
    }
    int max = array[0],min=array[0];
    for (int i = 0; i < 10; i++)
    {
        if (array[i]>max)
        {
            max=array[i];
        }
        if (array[i]<min)
        {
           min = array[i];
        }
    }
    printf("%d %d ", min , max);
    return 0;
}
